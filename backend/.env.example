# Server Configuration
NODE_ENV=development
PORT=3000

# Database
MONGO_URI=mongodb://localhost:27017/casemaster

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=30d
JWT_COOKIE_EXPIRES_IN=30

# Encryption Key (REQUIRED for production - generate a 64-character hex string)
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-key-change-in-production

# Email Configuration (Brevo/Sendinblue)
# Get your API key from https://app.brevo.com/settings/keys
BREVO_API_KEY=your-brevo-api-key-here

# Sender email - must be verified in Brevo
SENDINBLUE_EMAIL=noreply@lawmaster.ng
SENDINBLUE_NAME=LawMaster

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# Platform Admin Configuration
# Strong random string minimum 32 characters — only you know this
PLATFORM_ADMIN_SECRET=your-32-character-minimum-random-string
# Your email address as platform owner
PLATFORM_ADMIN_EMAIL=admin@lawmaster.ng

# File Storage (optional)
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_BUCKET_NAME=your-bucket-name
# AWS_REGION=us-east-1

# Payment Gateway (optional)
# PAYSTACK_SECRET_KEY=your-paystack-secret
# PAYSTACK_PUBLIC_KEY=your-paystack-public
