doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Property Report - #{matter.matterNumber}
    style.
      * { margin: 0; padding: 0; box-sizing: border-box; }
      :root {
        --primary: #{firm && firm.settings && firm.settings.primaryColor ? firm.settings.primaryColor : '#1a365d'};
        --primary-light: #{firm && firm.settings && firm.settings.primaryColor ? firm.settings.primaryColor + '15' : '#1a365d15'};
        --secondary: #64748b;
        --success: #059669;
        --warning: #d97706;
        --danger: #dc2626;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-700: #334155;
        --gray-900: #0f172a;
      }
      body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; line-height: 1.4; color: var(--gray-900); background: #ffffff; font-size: 11px; }
      .report-wrapper { max-width: 100%; margin: 0; padding: 20px; }
      
      .report-header { display: flex; justify-content: space-between; align-items: flex-start; padding-bottom: 12px; border-bottom: 2px solid var(--primary); margin-bottom: 15px; }
      .firm-brand { display: flex; align-items: center; gap: 10px; }
      .firm-logo { width: 40px; height: 40px; background: var(--primary); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 18px; }
      .firm-details h1 { font-size: 16px; font-weight: 700; color: var(--gray-900); }
      .firm-details p { font-size: 10px; color: var(--secondary); }
      .report-title-section { text-align: right; }
      .report-title { font-size: 20px; font-weight: 700; color: var(--primary); text-transform: uppercase; }
      .report-date { font-size: 9px; color: var(--secondary); margin-top: 4px; }
      
      .matter-info { background: var(--gray-50); border-radius: 8px; padding: 12px; margin-bottom: 15px; border: 1px solid var(--gray-200); }
      .matter-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
      .matter-number { font-size: 14px; font-weight: 700; color: var(--primary); }
      .matter-type { display: inline-block; padding: 2px 8px; background: var(--primary-light); color: var(--primary); border-radius: 10px; font-size: 9px; font-weight: 600; text-transform: uppercase; }
      .matter-details-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
      .detail-item { font-size: 10px; }
      .detail-label { color: var(--secondary); font-weight: 500; }
      .detail-value { color: var(--gray-900); font-weight: 600; }
      
      .section { margin-bottom: 15px; }
      .section-title { font-size: 12px; font-weight: 600; color: var(--gray-900); margin: 12px 0 10px 0; padding-bottom: 5px; border-bottom: 1px solid var(--primary); }
      
      .info-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
      .info-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 12px; }
      .info-card { background: var(--gray-50); border-radius: 6px; padding: 10px; border: 1px solid var(--gray-200); }
      .info-card-title { font-size: 9px; font-weight: 600; color: var(--secondary); text-transform: uppercase; margin-bottom: 8px; padding-bottom: 5px; border-bottom: 1px solid var(--gray-200); }
      .info-row { display: flex; justify-content: space-between; padding: 4px 0; font-size: 10px; }
      .info-label { color: var(--secondary); font-weight: 500; }
      .info-value { color: var(--gray-900); font-weight: 600; text-align: right; }
      
      table { width: 100%; border-collapse: collapse; margin-bottom: 12px; font-size: 10px; border-radius: 6px; overflow: hidden; }
      thead { background: var(--primary); color: white; }
      th { padding: 8px 6px; text-align: left; font-weight: 600; font-size: 9px; text-transform: uppercase; }
      td { padding: 8px 6px; border-bottom: 1px solid var(--gray-100); color: var(--gray-700); }
      tbody tr:hover { background: var(--gray-50); }
      .amount { text-align: right; font-weight: 600; }
      
      .status-badge { display: inline-block; padding: 2px 6px; border-radius: 8px; font-size: 8px; font-weight: 600; text-transform: uppercase; }
      .status-completed, .status-paid, .status-registered { background: #d1fae5; color: #065f46; }
      .status-pending { background: #fef3c7; color: #92400e; }
      .status-overdue { background: #fee2e2; color: #991b1b; }
      .status-active, .status-executed { background: #dbeafe; color: #1e40af; }
      .status-draft { background: #f1f5f9; color: #475569; }
      .status-met { background: #d1fae5; color: #065f46; }
      
      .financial-box { background: var(--primary-light); border: 1px solid var(--primary); border-radius: 8px; padding: 12px; margin: 12px 0; }
      .financial-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
      .financial-item { text-align: center; }
      .financial-label { font-size: 9px; font-weight: 600; color: var(--secondary); text-transform: uppercase; margin-bottom: 4px; }
      .financial-value { font-size: 16px; font-weight: 700; color: var(--primary); font-family: 'Courier New', monospace; }
      .financial-value.success { color: var(--success); }
      
      .checklist { background: white; border: 1px solid var(--gray-200); border-radius: 6px; overflow: hidden; }
      .checklist-item { display: flex; align-items: flex-start; padding: 8px 10px; border-bottom: 1px solid var(--gray-100); font-size: 10px; }
      .checklist-item:last-child { border-bottom: none; }
      .checklist-icon { width: 16px; height: 16px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-right: 8px; font-size: 8px; flex-shrink: 0; }
      .checklist-icon.completed { background: #d1fae5; color: #065f46; }
      .checklist-icon.pending { background: #fef3c7; color: #92400e; }
      .checklist-icon.missing { background: #fee2e2; color: #991b1b; }
      .checklist-label { flex: 1; color: var(--gray-700); }
      
      .findings-box { background: #fffbeb; border: 1px solid #f59e0b; border-radius: 6px; padding: 12px; margin: 10px 0; }
      .findings-title { font-size: 10px; font-weight: 600; color: #92400e; margin-bottom: 8px; text-transform: uppercase; }
      .findings-text { font-size: 10px; color: #78350f; line-height: 1.5; white-space: pre-wrap; }
      
      .report-footer { margin-top: 20px; padding-top: 12px; border-top: 1px solid var(--gray-200); text-align: center; }
      .footer-text { font-size: 9px; color: var(--secondary); }
      .footer-firm { font-size: 12px; font-weight: 600; color: var(--primary); }
      
      .text-right { text-align: right; }
      @media print { body { -webkit-print-color-adjust: exact; } }

  body
    .report-wrapper
      //- Header
      .report-header
        .firm-brand
          .firm-logo P
          .firm-details
            h1 #{firm && firm.name ? firm.name : 'Law Firm'}
            p Barristers, Solicitors & Advocates
        .report-title-section
          .report-title PROPERTY REPORT
          .report-date Generated: #{new Date().toLocaleDateString('en-GB')}
      
      //- Matter Info
      .matter-info
        .matter-header
          div
            .matter-number #{matter.matterNumber}
            .matter-type #{matter.natureOfMatter ? matter.natureOfMatter.replace(/_/g, ' ') : 'Property'}
          div
            - var statusClass = 'status-' + (matter.status === 'active' ? 'active' : matter.status === 'completed' ? 'completed' : 'pending')
            span.status-badge(class=statusClass) #{matter.status || 'Active'}
        
        .matter-details-grid
          .detail-item
            .detail-label Client
            .detail-value #{matter.client ? matter.client.firstName + ' ' + matter.client.lastName : 'N/A'}
          .detail-item
            .detail-label Matter Type
            .detail-value #{matter.matterType ? matter.matterType.replace(/_/g, ' ').toUpperCase() : 'Property'}
          .detail-item
            .detail-label Date Opened
            .detail-value #{matter.dateOpened ? new Date(matter.dateOpened).toLocaleDateString('en-GB') : 'N/A'}
          .detail-item
            .detail-label Assigned To
            .detail-value #{matter.assignedTo ? matter.assignedTo.firstName + ' ' + matter.assignedTo.lastName : 'N/A'}
      
      //- Transaction Details
      .section
        .section-title TRANSACTION DETAILS
        
        .info-grid-2
          .info-card
            .info-card-title Transaction Information
            .info-row
              .info-label Transaction Type
              .info-value #{propertyDetails.transactionType ? propertyDetails.transactionType.replace(/_/g, ' ').toUpperCase() : 'N/A'}
            .info-row
              .info-label Purchase Price
              .info-value ₦#{propertyDetails.purchasePrice ? propertyDetails.purchasePrice.toLocaleString('en-NG') : 'N/A'}
            .info-row
              .info-label Rent Amount
              .info-value ₦#{propertyDetails.rentAmount ? propertyDetails.rentAmount.toLocaleString('en-NG') : 'N/A'}
            .info-row
              .info-label Payment Terms
              .info-value #{propertyDetails.paymentTerms ? propertyDetails.paymentTerms.replace(/_/g, ' ').toUpperCase() : 'N/A'}
          
          .info-card
            .info-card-title Financial Summary
            .info-row
              .info-label Total Amount
              .info-value ₦#{(propertyDetails.purchasePrice || propertyDetails.rentAmount || 0).toLocaleString('en-NG')}
            .info-row
              .info-label Amount Paid
              .info-value ₦#{(propertyDetails.amountPaid || 0).toLocaleString('en-NG')}
            .info-row
              .info-label Balance
              .info-value ₦#{((propertyDetails.purchasePrice || propertyDetails.rentAmount || 0) - (propertyDetails.amountPaid || 0)).toLocaleString('en-NG')}
            .info-row
              .info-label Payment Progress
              .info-value #{propertyDetails.paymentSchedule ? Math.round((propertyDetails.paymentSchedule.filter(p => p.status === 'paid').length / propertyDetails.paymentSchedule.length) * 100) : 0}%
      
      //- Properties
      if propertyDetails.properties && propertyDetails.properties.length > 0
        .section
          .section-title PROPERTY DETAILS
          
          table
            thead
              tr
                th Type
                th Address
                th Title
                th Size
                th.text-right Amount
            tbody
              each prop in propertyDetails.properties
                tr
                  td #{prop.propertyType ? prop.propertyType.replace(/_/g, ' ').toUpperCase() : 'N/A'}
                  td #{prop.address || 'N/A'}
                  td #{prop.titleDocumentType || 'N/A'}
                  td #{prop.landSize ? prop.landSize.value + ' ' + prop.landSize.unit : 'N/A'}
                  td.amount ₦#{(prop.amount || 0).toLocaleString('en-NG')}
      
      //- Title Search & Due Diligence
      if propertyDetails.titleSearch
        .section
          .section-title DUE DILIGENCE - TITLE SEARCH
          
          .info-grid-3
            .info-card
              .info-card-title Title Search Status
              .info-row
                .info-label Completed
                .info-value #{propertyDetails.titleSearch.isCompleted ? 'YES' : 'NO'}
              .info-row
                .info-label Search Date
                .info-value #{propertyDetails.titleSearch.searchDate ? new Date(propertyDetails.titleSearch.searchDate).toLocaleDateString('en-GB') : 'N/A'}
              .info-row
                .info-label Title Number
                .info-value #{propertyDetails.titleSearch.titleNumber || 'N/A'}
            
            .info-card
              .info-card-title Survey Plan
              .info-row
                .info-label Available
                .info-value #{propertyDetails.surveyPlan && propertyDetails.surveyPlan.isAvailable ? 'YES' : 'NO'}
              .info-row
                .info-label Survey Number
                .info-value #{propertyDetails.surveyPlan ? propertyDetails.surveyPlan.surveyNumber || 'N/A' : 'N/A'}
              .info-row
                .info-label Survey Date
                .info-value #{propertyDetails.surveyPlan && propertyDetails.surveyPlan.surveyDate ? new Date(propertyDetails.surveyPlan.surveyDate).toLocaleDateString('en-GB') : 'N/A'}
            
            .info-card
              .info-card-title Governor's Consent
              .info-row
                .info-label Required
                .info-value #{propertyDetails.governorsConsent && propertyDetails.governorsConsent.isRequired ? 'YES' : 'N/A'}
              .info-row
                .info-label Status
                - var govStatus = propertyDetails.governorsConsent ? propertyDetails.governorsConsent.status || 'pending' : 'N/A'
                .info-value #{govStatus.replace(/-/g, ' ').toUpperCase()}
              .info-row
                .info-label Reference No
                .info-value #{propertyDetails.governorsConsent ? propertyDetails.governorsConsent.referenceNumber || 'N/A' : 'N/A'}
        
        if propertyDetails.titleSearch.findings
          .findings-box
            .findings-title TITLE SEARCH FINDINGS
            .findings-text #{propertyDetails.titleSearch.findings}
        
        if propertyDetails.titleSearch.encumbrances && propertyDetails.titleSearch.encumbrances.length > 0
          .findings-box
            .findings-title ENCUMBRANCES
            .findings-text #{propertyDetails.titleSearch.encumbrances.join(', ')}
      
      //- Physical Inspection
      if propertyDetails.physicalInspection
        .section
          .section-title PHYSICAL INSPECTION
          
          .info-grid-2
            .info-card
              .info-card-title Inspection Details
              .info-row
                .info-label Completed
                .info-value #{propertyDetails.physicalInspection.isCompleted ? 'YES' : 'NO'}
              .info-row
                .info-label Inspection Date
                .info-value #{propertyDetails.physicalInspection.inspectionDate ? new Date(propertyDetails.physicalInspection.inspectionDate).toLocaleDateString('en-GB') : 'N/A'}
          
          if propertyDetails.physicalInspection.findings
            .findings-box
              .findings-title INSPECTION FINDINGS
              .findings-text #{propertyDetails.physicalInspection.findings}
      
      //- Legal Documents Status
      .section
        .section-title LEGAL DOCUMENTS STATUS
        
        .info-grid-2
          if propertyDetails.contractOfSale
            .info-card
              .info-card-title Contract of Sale
              .info-row
                .info-label Status
                - var cosStatus = propertyDetails.contractOfSale.status || 'draft'
                - var cosClass = 'status-' + (cosStatus === 'completed' || cosStatus === 'executed' ? 'completed' : 'draft')
                span.status-badge(class=cosClass) #{cosStatus.toUpperCase()}
              .info-row
                .info-label Execution Date
                .info-value #{propertyDetails.contractOfSale.executionDate ? new Date(propertyDetails.contractOfSale.executionDate).toLocaleDateString('en-GB') : 'N/A'}
              .info-row
                .info-label Completion Date
                .info-value #{propertyDetails.contractOfSale.completionDate ? new Date(propertyDetails.contractOfSale.completionDate).toLocaleDateString('en-GB') : 'N/A'}
          
          if propertyDetails.deedOfAssignment
            .info-card
              .info-card-title Deed of Assignment
              .info-row
                .info-label Status
                - var doaStatus = propertyDetails.deedOfAssignment.status || 'pending'
                - var doaClass = 'status-' + (doaStatus === 'registered' ? 'completed' : doaStatus === 'executed' ? 'executed' : 'pending')
                span.status-badge(class=doaClass) #{doaStatus.toUpperCase()}
              .info-row
                .info-label Execution Date
                .info-value #{propertyDetails.deedOfAssignment.executionDate ? new Date(propertyDetails.deedOfAssignment.executionDate).toLocaleDateString('en-GB') : 'N/A'}
              .info-row
                .info-label Registration Date
                .info-value #{propertyDetails.deedOfAssignment.registrationDate ? new Date(propertyDetails.deedOfAssignment.registrationDate).toLocaleDateString('en-GB') : 'N/A'}
      
      //- Payment Schedule
      if propertyDetails.paymentSchedule && propertyDetails.paymentSchedule.length > 0
        .section
          .section-title PAYMENT SCHEDULE
          
          table
            thead
              tr
                th Description
                th Due Date
                th.text-right Amount
                th Status
            tbody
              each payment in propertyDetails.paymentSchedule
                tr
                  td #{payment.description || 'Payment #' + payment.installmentNumber}
                  td #{payment.dueDate ? new Date(payment.dueDate).toLocaleDateString('en-GB') : 'N/A'}
                  td.amount ₦#{(payment.amount || 0).toLocaleString('en-NG')}
                  td
                    - var payStatus = payment.status === 'paid' ? 'paid' : (payment.status === 'pending' && new Date(payment.dueDate) < new Date() ? 'overdue' : 'pending')
                    - var payClass = 'status-' + payStatus
                    span.status-badge(class=payClass) #{payment.status || 'Pending'}
      
      //- Conditions
      if propertyDetails.conditions && propertyDetails.conditions.length > 0
        .section
          .section-title CONDITIONS & OBLIGATIONS
          
          .checklist
            each condition in propertyDetails.conditions
              .checklist-item
                - var condStatus = condition.status === 'met' ? 'completed' : (condition.status === 'pending' ? 'pending' : 'missing')
                .checklist-icon(class=condStatus) #{condition.status === 'met' ? '✓' : condition.status === 'pending' ? '!' : '✗'}
                .checklist-label #{condition.condition || condition.description || 'Condition'}
      
      //- Parties
      .section
        .section-title PARTIES INVOLVED
        
        .info-grid-2
          if propertyDetails.vendor || propertyDetails.purchaser
            .info-card
              .info-card-title #{propertyDetails.transactionType === 'sale' ? 'SELLER' : 'BUYER'}
              if propertyDetails.vendor
                .info-row
                  .info-label Name
                  .info-value #{propertyDetails.vendor.name || 'N/A'}
                .info-row
                  .info-label Contact
                  .info-value #{propertyDetails.vendor.contact || 'N/A'}
              if propertyDetails.purchaser
                .info-row
                  .info-label Name
                  .info-value #{propertyDetails.purchaser.name || 'N/A'}
                .info-row
                  .info-label Contact
                  .info-value #{propertyDetails.purchaser.contact || 'N/A'}
          
          if propertyDetails.landlord || propertyDetails.tenant
            .info-card
              .info-card-title #{propertyDetails.transactionType === 'lease' ? 'LANDLORD' : 'TENANT'}
              if propertyDetails.landlord
                .info-row
                  .info-label Name
                  .info-value #{propertyDetails.landlord.name || 'N/A'}
                .info-row
                  .info-label Contact
                  .info-value #{propertyDetails.landlord.contact || 'N/A'}
              if propertyDetails.tenant
                .info-row
                  .info-label Name
                  .info-value #{propertyDetails.tenant.name || 'N/A'}
                .info-row
                  .info-label Contact
                  .info-value #{propertyDetails.tenant.contact || 'N/A'}
      
      //- Footer
      .report-footer
        .footer-text This is a computer-generated report and does not require a signature.
        .footer-firm #{firm && firm.name ? firm.name : 'Law Firm'}
