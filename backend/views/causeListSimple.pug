doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Upcoming Hearings - #{periodName}
    style.
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { 
        font-family: 'Segoe UI', Arial, sans-serif; 
        font-size: 11px; 
        line-height: 1.4; 
        color: #333;
        padding: 15px;
      }
      .header {
        text-align: center;
        margin-bottom: 20px;
        border-bottom: 2px solid #1a237e;
        padding-bottom: 15px;
      }
      .header h1 {
        font-size: 20px;
        color: #1a237e;
        margin-bottom: 5px;
        text-transform: uppercase;
      }
      .header .subtitle {
        font-size: 12px;
        color: #666;
      }
      .period {
        text-align: center;
        background: #f5f5f5;
        padding: 10px;
        margin-bottom: 15px;
        border-radius: 4px;
      }
      .period-name {
        font-size: 14px;
        font-weight: bold;
        color: #1a237e;
      }
      .period-dates {
        font-size: 11px;
        color: #666;
        margin-top: 3px;
      }
      .stats {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-bottom: 15px;
        font-size: 11px;
      }
      .stat {
        background: #e8eaf6;
        padding: 5px 12px;
        border-radius: 3px;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 10px;
      }
      th {
        background: #1a237e;
        color: white;
        padding: 8px 6px;
        text-align: left;
        font-weight: 600;
        font-size: 10px;
      }
      td {
        padding: 7px 6px;
        border-bottom: 1px solid #ddd;
        vertical-align: top;
      }
      tr:nth-child(even) td { background: #f9f9f9; }
      tr:hover td { background: #e8eaf6; }
      .sn { width: 30px; text-align: center; font-weight: bold; }
      .date-col { width: 80px; }
      .date-day { font-weight: bold; color: #1a237e; }
      .date-weekday { font-size: 9px; color: #666; }
      .case-info { width: 25%; }
      .case-title { font-weight: 600; font-size: 10px; }
      .case-no { font-size: 9px; color: #666; font-family: monospace; }
      .court-col { width: 18%; }
      .court-name { font-weight: 500; }
      .court-details { font-size: 9px; color: #666; }
      .purpose-col { width: 15%; }
      .lawyers-col { width: 20%; }
      .lawyer { font-size: 9px; margin-bottom: 2px; }
      .no-data {
        text-align: center;
        padding: 40px;
        color: #999;
        font-style: italic;
      }
      .footer {
        margin-top: 15px;
        text-align: center;
        font-size: 9px;
        color: #999;
        border-top: 1px solid #ddd;
        padding-top: 10px;
      }

body
  .header
    h1= firm ? firm.name : firmName
    .subtitle #{firm && firm.address ? firm.address : 'LEGAL PRACTITIONERS & SOLICITORS'}
  
  .period
    .period-name UPCOMING HEARINGS - #{periodName}
    .period-dates #{startDate} - #{endDate}
  
  .stats
    .stat Total Cases: #{totalHearings || hearings.length}
  
  if hearings && hearings.length > 0
    table
      thead
        tr
          th.sn NO.
          th.date-col DATE
          th.case-info CASE DETAILS
          th.court-col COURT
          th.purpose-col PURPOSE
          th.lawyers-col LAWYERS
      tbody
        each hearing, index in hearings
          tr
            td.sn #{index + 1}
            td.date-col
              .date-day #{hearing.hearingDate ? new Date(hearing.hearingDate).toLocaleDateString('en-GB', {day: '2-digit', month: '2-digit', year: 'numeric'}) : 'N/A'}
              .date-weekday #{hearing.hearingDay || ''}
            td.case-info
              .case-title #{hearing.matterTitle || 'N/A'}
              .case-no #{hearing.suitNo || ''}
              if hearing.client
                .case-no Client: #{hearing.client.firstName} #{hearing.client.lastName}
            td.court-col
              .court-name #{hearing.courtName || 'N/A'}
              .court-details #{hearing.courtNo ? 'Court No: ' + hearing.courtNo : ''} #{hearing.courtLocation ? ' - ' + hearing.courtLocation : ''}
              if hearing.judge
                .court-details Judge: #{hearing.judge}
            td.purpose-col
              | #{hearing.purpose || 'N/A'}
            td.lawyers-col
              if hearing.lawyerPresent && hearing.lawyerPresent.length > 0
                each lawyer in hearing.lawyerPresent
                  .lawyer #{lawyer.firstName} #{lawyer.lastName}
              else
                .lawyer No counsel assigned
  else
    .no-data No hearings scheduled for this period
  
  .footer
    | Document generated on #{generatedAt}
